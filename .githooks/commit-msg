#!/bin/sh
# Opt-in local Conventional Commits check (no npm, no husky).
# Enable once:  git config core.hooksPath .githooks
msg=$(head -1 "$1")
# allow merge/revert/fixup commits through
case "$msg" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9 ._/-]+\))?!?: .+'
if ! printf '%s' "$msg" | grep -Eq "$pattern"; then
  echo "✗ commit message is not Conventional Commits:"
  echo "    $msg"
  echo "  expected:  <type>(<scope>)?: <subject>"
  echo "  types:     feat fix docs style refactor perf test build ci chore revert"
  echo "  example:   feat(skill): add a new check"
  exit 1
fi
